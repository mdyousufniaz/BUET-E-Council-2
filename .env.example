BACKEND_URL=http://localhost:9001

# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=buet_admin_pass
POSTGRES_DB=ecouncil_db
DATABASE_URL=postgresql://admin:buet_admin_pass@db:5432/ecouncil_db

# Security / Auth
SECRET_KEY=your_super_secret_buet_key

# Comma-separated list of origins allowed to make cookie-authenticated
# requests (CORS + CSRF origin check in auth_service/meeting_service).
# Should match the URL the app is actually served at - i.e. BACKEND_URL above.
ALLOWED_ORIGINS=http://localhost:9001

# Optional: Hugging Face access token, used only at build time to speed up
# downloading the embedding_service's sentence-transformers/LaBSE model.
# Leave blank for anonymous (rate-limited) downloads.
HF_TOKEN=

# Email / SMTP Configuration
# Works with any SMTP-speaking server (Gmail, SES, Mailgun, Postmark, a
# self-hosted mail server, etc.) - swap these to move mail sending elsewhere,
# no code changes needed. Leave SMTP_HOST unset to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@buet-ecouncil.local

# MinIO / Object Storage Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
R3_REGION=us-east-1
R3_ENDPOINT=http://minio:9000
R3_ACCESS_KEY_ID=minioadmin
R3_SECRET_ACCESS_KEY=minioadmin
R3_BUCKET_NAME=ecouncil-bucket

# Max size (MB) for a single annexure upload. Allowed formats are set
# separately in meeting_service/config/annexureUpload.js.
MAX_ANNEXURE_SIZE_MB=50
